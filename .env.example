# Gmail SMTP（Googleアカウントのアプリパスワードを使用）
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # 16文字のGoogleアプリパスワード

# 送信先メールアドレス
TO_EMAIL=recipient@example.com

# Twitter/X API v2 Bearer Token（オプション・未設定ならXをスキップ）
X_BEARER_TOKEN=

# 収集設定（オプション・デフォルト値あり）
NOTE_ARTICLES_PER_TAG=10
HATENA_ENTRIES_COUNT=20
X_POSTS_COUNT=20
X_MIN_LIKES=500
